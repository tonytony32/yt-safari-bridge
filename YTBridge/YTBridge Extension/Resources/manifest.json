{
  "manifest_version": 3,
  "name": "YT Bridge",
  "version": "0.1.0",
  "description": "Exposes YouTube / YouTube Music playback state to a local process (JellySleeve) via native messaging.",
  "permissions": ["nativeMessaging", "scripting"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://music.youtube.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["common.js", "content/youtube.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["common.js", "content/ytmusic.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
