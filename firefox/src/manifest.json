{
  "manifest_version": 3,
  "name": "YT Bridge",
  "version": "0.1.0",
  "description": "Exposes YouTube / YouTube Music playback state to a local process (JellyBeat) via a loopback bridge.",
  "permissions": ["scripting", "alarms"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://music.youtube.com/*",
    "http://127.0.0.1:8976/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ytbridge@trypwood.com",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["firefox-config.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["common.js", "content/youtube.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["common.js", "content/ytmusic.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
